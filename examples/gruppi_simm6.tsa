inv(X*Y)=inv(Y)*inv(X)
r2*(r1*r2)=r1*(r2*r1)
r2*(r1*(r2*Z))=r1*(r2*(r1*Z))
r3*(r2*r3)=r2*(r3*r2)
r3*(r2*(r3*Z))=r2*(r3*(r2*Z))
