(r2*r3)*(r2*r3)*(r2*r3)=1
(r3*r4)*(r3*r4)*(r3*r4)=1
(r4*r5)*(r4*r5)*(r4*r5)=1

[ORDINE]
inv>*>1>r5>r4>r3>r2>r1

